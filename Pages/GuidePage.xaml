<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SkyeMinder.Pages.GuidePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ScrollView>
        <VerticalStackLayout Spacing="18" Padding="24">

            <Label Text="Welcome to Skye Minder"
                   FontSize="24"
                   FontAttributes="Bold" />

            <Label Text="This guide will help you understand how reminders work and how to keep them reliable." />

            <Label Text="Battery Optimization"
                   FontSize="18"
                   FontAttributes="Bold" />

            <Label Text="Android may pause apps in the background to save battery. Turning off battery optimization helps ensure reminders fire on time." />

            <Button Text="Open Battery Optimization Settings"
                    Clicked="OnOpenSettingsClicked" />

            <Label Text="How Reminders Work"
                   FontSize="18"
                   FontAttributes="Bold" />

            <Label Text="Skye Minder schedules reminders using the system alarm manager. If the system restricts the app, reminders may be delayed until the app is reopened." />

            <Label Text="Tips for reliability:" />
            <Label Text="• Disable battery optimization for Skye Minder." />
            <Label Text="• Keep notifications enabled." />
            <Label Text="• Avoid force-closing the app." />
            <Label Text="• Keep automatic date and time enabled." />

            <Label Text="Permission auto‑revoke" 
               FontSize="18"
               FontAttributes="Bold" />
            <Label Text="Android can remove permissions from apps you haven't opened in a while." />
            <Label Text="This doesn't affect reminders today, but it can cause problems months later." />
            <Label Text="To prevent this, you can turn off 'Manage app if unused' in the app's settings. This will prevent Android from removing permissions if the app isn't opened for a long time." />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>